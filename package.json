{
  "name": "kehong-paper-site",
  "version": "0.1.0",
  "private": true,
  "description": "Multilingual B2B catalog and inquiry site for Foshan Kehong Paper Products.",
  "author": "Foshan Kehong Paper Products Co., Ltd.",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/validate-email-config.mjs && node scripts/validate-catalog.mjs && node scripts/validate-sitemap.mjs && node scripts/audit-legacy-domain.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "site:health": "node scripts/site-health.mjs",
    "validate:sitemap": "node scripts/validate-sitemap.mjs",
    "import:catalog": "node scripts/import-kehong-catalog.mjs",
    "build:product-data": "node scripts/build-product-data.mjs",
    "build:image-candidates": "node scripts/build-image-candidates.mjs",
    "build:source-decisions": "node scripts/build-source-decisions.mjs",
    "validate:product-assets": "node scripts/validate-product-assets.mjs",
    "audit:product-data": "node scripts/audit-product-data.mjs",
    "audit:public-data": "node scripts/audit-public-product-data.mjs",
    "audit:public-pages": "node scripts/audit-public-product-pages.mjs",
    "validate:catalog": "node scripts/validate-catalog.mjs",
    "validate:products": "node scripts/validate-catalog.mjs && node scripts/validate-product-assets.mjs",
    "migrate:product-taxonomy": "node scripts/migrate-product-taxonomy.mjs",
    "audit:legacy-domain": "node scripts/audit-legacy-domain.mjs",
    "validate:image-refs": "node scripts/validate-public-image-refs.mjs",
    "validate:image-candidates": "node scripts/validate-candidate-images.mjs",
    "validate:ai-assets": "node scripts/validate-ai-generated-assets.mjs",
    "validate:asset-refs": "node scripts/validate-public-asset-refs.mjs",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "ci": "pnpm install --frozen-lockfile && pnpm run lint && pnpm run typecheck && pnpm run validate:products && pnpm run audit:legacy-domain && pnpm run test:unit && pnpm run build && pnpm run test:e2e"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "next": "^16.2.9",
    "next-intl": "^4.13.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.185.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.9",
    "@playwright/test": "^1.53.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
